// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ───────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  name          String
  phone         String?
  avatar        String?
  role          Role     @default(CLIENT)
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  googleId      String?  @unique
  facebookId    String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  whatsappNumber String?

  // Relaciones
  appointments            Appointment[]
  reviews                 Review[]
  ownedShops              Barbershop[]              @relation("ShopOwner")
  barberProfile           Barber?
  notifications           Notification[]
  loyaltyPoints           LoyaltyPoint[]
  clientLoyalties         ClientLoyalty[]
  notificationPreference  NotificationPreference?
  waitlists               Waitlist[]

  @@map("users")
}

enum Role {
  CLIENT
  OWNER
  BARBER
  ADMIN
}

// ─── BARBERÍAS ──────────────────────────────────────────
model Barbershop {
  id           String   @id @default(uuid())
  name         String
  description  String?
  address      String
  city         String
  latitude     Float?
  longitude    Float?
  phone        String?
  email        String?
  instagram    String?
  facebook     String?
  logo         String?
  coverImage   String?
  isActive     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  plan         Plan     @default(BASIC)
  planExpiresAt DateTime?
  ownerId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  owner           User              @relation("ShopOwner", fields: [ownerId], references: [id])
  barbers         Barber[]
  services        Service[]
  appointments    Appointment[]
  reviews         Review[]
  schedules       Schedule[]
  photos          ShopPhoto[]
  config          BarberShopConfig?
  clientLoyalties ClientLoyalty[]
  advertisements  Advertisement[]
  waitlists       Waitlist[]
  subscription    Subscription?
  offers          Offer[]

  @@map("barbershops")
}

enum Plan {
  BASIC
  PREMIUM
  STANDARD
}

// ─── BARBEROS ───────────────────────────────────────────
model Barber {
  id           String   @id @default(uuid())
  userId       String   @unique
  barbershopId String
  specialty    String?
  bio          String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  user         User        @relation(fields: [userId], references: [id])
  barbershop   Barbershop  @relation(fields: [barbershopId], references: [id])
  appointments Appointment[]
  reviews      Review[]
  waitlists    Waitlist[]

  @@map("barbers")
}

// ─── SERVICIOS ──────────────────────────────────────────
model Service {
  id           String   @id @default(uuid())
  barbershopId String
  name         String
  description  String?
  price        Float
  duration     Int      // duración en minutos
  image        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  appointments Appointment[]
  waitlists    Waitlist[]
  offers       Offer[]

  @@map("services")
}

// ─── CITAS ──────────────────────────────────────────────
model Appointment {
  id           String            @id @default(uuid())
  clientId     String
  barbershopId String
  barberId     String
  serviceId    String
  date         DateTime
  startTime    String            // "09:00"
  endTime      String            // "09:30"
  status       AppointmentStatus @default(PENDING)
  totalPrice   Float
  notes        String?
  cancelReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relaciones
  client       User       @relation(fields: [clientId], references: [id])
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  barber       Barber     @relation(fields: [barberId], references: [id])
  service      Service    @relation(fields: [serviceId], references: [id])
  payment      Payment?
  review       Review?

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── PAGOS ──────────────────────────────────────────────
model Payment {
  id            String        @id @default(uuid())
  appointmentId String        @unique
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relaciones
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  @@map("payments")
}

enum PaymentMethod {
  CARD
  PSE
  NEQUI
  DAVIPLATA
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── RESEÑAS ────────────────────────────────────────────
model Review {
  id           String   @id @default(uuid())
  clientId     String
  barbershopId String
  barberId     String?
  appointmentId String  @unique
  rating       Int      // 1 al 5
  comment      String?
  createdAt    DateTime @default(now())

  // Relaciones
  client       User        @relation(fields: [clientId], references: [id])
  barbershop   Barbershop  @relation(fields: [barbershopId], references: [id])
  barber       Barber?     @relation(fields: [barberId], references: [id])
  appointment  Appointment @relation(fields: [appointmentId], references: [id])

  @@map("reviews")
}

// ─── HORARIOS ───────────────────────────────────────────
model Schedule {
  id           String   @id @default(uuid())
  barbershopId String
  dayOfWeek    Int      // 0=Domingo, 1=Lunes ... 6=Sábado
  openTime     String   // "08:00"
  closeTime    String   // "20:00"
  isOpen       Boolean  @default(true)

  // Relaciones
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("schedules")
}

// ─── FOTOS DE BARBERÍA ──────────────────────────────────
model ShopPhoto {
  id           String   @id @default(uuid())
  barbershopId String
  url          String
  caption      String?
  createdAt    DateTime @default(now())

  // Relaciones
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("shop_photos")
}

// ─── NOTIFICACIONES ─────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relaciones
  user      User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── PUNTOS DE FIDELIDAD ────────────────────────────────
model LoyaltyPoint {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  description String
  createdAt   DateTime @default(now())

  // Relaciones
  user        User @relation(fields: [userId], references: [id])

  @@map("loyalty_points")
}

// ─── CONFIGURACIÓN DE BARBERÍA ─────────────────────────
model BarberShopConfig {
  id                    String     @id @default(uuid())
  barbershopId          String     @unique
  barberPercentage      Float      @default(60)   // % que se lleva el barbero
  shopPercentage        Float      @default(40)   // % que se lleva la barbería
  loyaltyEnabled        Boolean    @default(true)
  cutsForFreeService    Int        @default(10)   // cada cuántos cortes hay uno gratis
  cancellationWindowMin Int        @default(60)   // minutos antes para cancelar sin penalidad
  appointmentDuration   Int        @default(40)   // duración fija en minutos
  toleranceMinutes      Int        @default(10)   // tolerancia de llegada
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relaciones
  barbershop            Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("barbershop_configs")
}

// ─── FIDELIZACIÓN DE CLIENTES ──────────────────────────
model ClientLoyalty {
  id             String      @id @default(uuid())
  clientId       String
  barbershopId   String
  totalCuts      Int         @default(0)
  freeCutsEarned Int         @default(0)
  freeCutsUsed   Int         @default(0)
  lastVisit      DateTime?

  // Relaciones
  client         User        @relation(fields: [clientId], references: [id])
  barbershop     Barbershop  @relation(fields: [barbershopId], references: [id])

  @@unique([clientId, barbershopId])
  @@map("client_loyalties")
}

// ─── PUBLICIDAD ────────────────────────────────────────
model Advertisement {
  id            String     @id @default(uuid())
  barbershopId  String
  title         String
  mediaUrl      String     // URL del video o imagen en Cloudinary
  mediaType     String     // "video" o "image"
  isActive      Boolean    @default(true)
  startsAt      DateTime
  endsAt        DateTime
  isPaid        Boolean    @default(false)
  amountPaid    Float?
  clicks        Int        @default(0)
  views         Int        @default(0)
  createdAt     DateTime   @default(now())

  // Relaciones
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("advertisements")
}

// ─── PREFERENCIAS DE NOTIFICACIÓN ──────────────────────
model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @unique
  whatsappNumber  String?
  preferWhatsapp  Boolean  @default(false)
  preferPush      Boolean  @default(true)
  reminderEnabled Boolean  @default(true)

  // Relaciones
  user            User     @relation(fields: [userId], references: [id])

  @@map("notification_preferences")
}

// ─── LISTA DE ESPERA ────────────────────────────────────
model Waitlist {
  id            String         @id @default(uuid())
  barbershopId  String
  barberId      String
  serviceId     String
  clientId      String
  date          DateTime
  preferredTime String?
  status        WaitlistStatus @default(WAITING)
  position      Int
  notifiedAt    DateTime?
  createdAt     DateTime       @default(now())

  // Relaciones
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  barber        Barber     @relation(fields: [barberId], references: [id])
  service       Service    @relation(fields: [serviceId], references: [id])
  client        User       @relation(fields: [clientId], references: [id])

  @@unique([clientId, barberId, date])
  @@map("waitlists")
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
}

// ─── SUSCRIPCIONES ──────────────────────────────────────
model Subscription {
  id             String             @id @default(uuid())
  barbershopId   String             @unique
  plan           Plan               @default(BASIC)
  status         SubscriptionStatus @default(ACTIVE)
  startDate      DateTime           @default(now())
  endDate        DateTime
  autoRenew      Boolean            @default(true)
  amountPaid     Float
  paymentMethod  String?
  transactionRef String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relaciones
  barbershop     Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

// ─── OFERTAS ────────────────────────────────────────────
model Offer {
  id            String     @id @default(uuid())
  barbershopId  String
  title         String
  description   String?
  discountPct   Float
  discountFixed Float?
  serviceId     String?
  validFrom     DateTime
  validUntil    DateTime
  maxUses       Int?
  currentUses   Int        @default(0)
  code          String?    @unique
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())

  // Relaciones
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])
  service       Service?   @relation(fields: [serviceId], references: [id])

  @@map("offers")
}

// ─── LOG DE BÚSQUEDAS ───────────────────────────────────
model SearchLog {
  id        String   @id @default(uuid())
  query     String
  city      String?
  userId    String?
  results   Int
  createdAt DateTime @default(now())

  @@map("search_logs")
}